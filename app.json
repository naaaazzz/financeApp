{
  "expo": {
    "name": "Fortune Flow",
    "slug": "income-expense-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/spending.png",
    "scheme": "incomeexpensetracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/spending.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0C16",
        "foregroundImage": "./assets/images/spending.png",
        "monochromeImage": "./assets/images/spending.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.niyasnas.incomeexpensetracker",
      "usesCleartextTraffic": true,
      "allowBackup": false,
      "newArchEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18666bef-801f-49fa-81b5-76072d3a2f74"
      }
    }
  }
}
